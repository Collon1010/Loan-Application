body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f4f6f9;
    color: #333;
}

header {
    background: #0052cc;
    color: white;
    text-align: center;
    padding: 40px 20px;
}

section {
    max-width: 700px;
    margin: 50px auto;
    background: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
    text-align: center;
}

button {
    background: #00b894;
    color: white;
    border: none;
    padding: 15px 30px;
    font-size: 18px;
    border-radius: 6px;
    cursor: pointer;
}

button:hover {
    background: #009874;
}

footer {
    text-align: center;
    padding: 20px;
    color: #777;
}
